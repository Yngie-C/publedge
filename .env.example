# Publedge environment variables
# Copy this file to .env.local and fill in values for your local environment.
# Do not commit .env.local or real secret values.

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase client/server
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase server-only secret
# The code accepts SUPABASE_SECRET_KEY and also falls back to SUPABASE_SERVICE_ROLE_KEY in some places.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — used for TTS and AI features such as summarize/proofread/translate/cover.
OPENAI_API_KEY=

# Toss Payments
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# Optional TTS providers
DASHSCOPE_API_KEY=
